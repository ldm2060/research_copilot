{
  "servers": {
    "arxiv-search": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-u",
        "${workspaceFolder}/.vscode/mcp-servers/arxiv-search/server.py"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1",
        "PYTHONUNBUFFERED": "1"
      }
    },
    "dblp-bib": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-u",
        "${workspaceFolder}/.vscode/mcp-servers/dblp-bib/server.py"
